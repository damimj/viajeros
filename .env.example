# ==============================================================================
# Supabase
# ==============================================================================
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api

# Public URL of your Supabase project (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key (safe to expose to browser, protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (SERVER-SIDE ONLY — never expose to browser)
# Used by API Routes for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==============================================================================
# Site configuration
# ==============================================================================
# Public URL of your deployed site (used for SEO, PWA manifest, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default site title (overridden by settings table if configured)
NEXT_PUBLIC_DEFAULT_SITE_TITLE=Viajeros

# ==============================================================================
# Map tiles (optional — uses free OpenStreetMap-based styles by default)
# ==============================================================================
# If you want to use MapTiler, Mapbox, or similar services, set your key here
# NEXT_PUBLIC_MAPTILER_KEY=
